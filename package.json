{
  "name": "autos-s4e",
  "version": "0.0.1605",
  "description": "prototype - a simple GraphQL demo rendered with Svelte and Tailwind",
  "author": "eswat2",
  "license": "MIT",
  "repository": "eswat2/autos-s4e",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "prebuild": "echo skipping pnpm format",
    "build": "pnpm twx; vite build",
    "serve": "vite preview",
    "cc": "prettier --check './src/**/*.{css,pcss,js,ts,svelte}'",
    "format": "prettier --write './src/**/*.{css,pcss,js,ts,svelte}'",
    "spell": "cspell './**/*.js'",
    "open": "open https://autos-s4e.vercel.app"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "autoprefixer": "10.5.0",
    "bumpp": "11.1.0",
    "concurrently": "9.2.1",
    "fetchql": "3.0.0",
    "only-allow": "1.2.2",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.2",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.499",
    "svelte": "5.55.8",
    "tailwindcss": "4.3.0",
    "vite": "8.0.13",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
